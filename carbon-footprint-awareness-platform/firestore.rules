rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /activities/{activityId} {
      allow read, write: if request.auth != null && (resource == null || request.auth.uid == resource.data.userId || request.auth.uid == request.resource.data.userId);
    }
    match /footprints/{footprintId} {
      allow read, write: if request.auth != null && (resource == null || request.auth.uid == resource.data.userId || request.auth.uid == request.resource.data.userId);
    }
    match /challenges/{challengeId} {
      allow read, write: if request.auth != null && (resource == null || request.auth.uid == resource.data.userId || request.auth.uid == request.resource.data.userId);
    }
    match /achievements/{achievementId} {
      allow read, write: if request.auth != null && (resource == null || request.auth.uid == resource.data.userId || request.auth.uid == request.resource.data.userId);
    }
    match /settings/{settingsId} {
      allow read, write: if request.auth != null && settingsId == request.auth.uid;
    }
  }
}
